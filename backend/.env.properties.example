# OAuth2 소셜 로그인
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_NAVER_CLIENT_ID=
OAUTH_NAVER_CLIENT_SECRET=
OAUTH_KAKAO_CLIENT_ID=
OAUTH_KAKAO_CLIENT_SECRET=

# DB
APP_DB_HOST=localhost
APP_DB_PORT=3307
APP_DB_NAME=demo
APP_DB_USERNAME=demo
APP_DB_PASSWORD=1234

# Mail (Gmail 기준)
APP_MAIL_HOST=smtp.gmail.com
APP_MAIL_PORT=587
APP_MAIL_USERNAME=
APP_MAIL_PASSWORD=
APP_MAIL_SMTP_AUTH=true
APP_MAIL_SMTP_STARTTLS_ENABLE=true
APP_MAIL_FROM=no-reply@example.com
APP_MAIL_AUTH_CODE_EXPIRE_MINUTES=5

# JWT
APP_JWT_SECRET=
APP_JWT_ACCESS_MINUTES=10
APP_JWT_REFRESH_DAYS=30

# Cookie
APP_COOKIE_SECURE=false
APP_COOKIE_SAMESITE=Lax

# PortOne
PORTONE_API_SECRET=
PORTONE_STORE_ID=

# 기타
APP_FRONTEND_URL=http://localhost
APP_UPLOAD_ROOT=./uploads
APP_CRAWLER_PYTHON_COMMAND=python
APP_CRAWLER_SCRIPT_PATH=src/main/java/com/example/demo/crawler/musinsa_catalog_crawler.py
